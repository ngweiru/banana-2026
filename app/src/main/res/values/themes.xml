    <style name="Theme.EWasteApp" parent="Base.Theme.EWasteApp" />

    <!-- Switch Theme -->
    <style name="SwitchTheme" parent="Theme.AppCompat.Light">
        <item name="colorControlActivated">#6FCF97</item>
        <item name="colorSwitchThumbNormal">#E0E0E0</item>
        <item name="android:colorForeground">#6FCF97</item>
    </style>
