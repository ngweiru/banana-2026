<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (LIGHT) -->
    <style name="Base.Theme.EWasteApp" parent="Theme.Material3.Light.NoActionBar">

        <!-- Primary Colors -->
        <item name="colorPrimary">#6FCF97</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorPrimaryDark">#5AB880</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">#CAEFD1</item>
        <item name="android:windowLightStatusBar">true</item>
