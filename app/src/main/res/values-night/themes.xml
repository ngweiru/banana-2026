<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (DARK) -->
    <style name="Base.Theme.EWasteApp" parent="Theme.Material3.Dark.NoActionBar">

        <!-- Primary Colors -->
        <item name="colorPrimary">#6FCF97</item>
        <item name="colorOnPrimary">#000000</item>
        <item name="colorPrimaryDark">#5AB880</item>

        <!-- Status Bar -->
        <item name="android:statusBarColor">#1A1A1A</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.EWasteApp" parent="Base.Theme.EWasteApp" />

    <!-- Switch Theme -->
    <style name="SwitchTheme" parent="Theme.AppCompat.Light">
        <item name="colorControlActivated">#6FCF97</item>
        <item name="colorSwitchThumbNormal">#E0E0E0</item>
        <item name="android:colorForeground">#6FCF97</item>
    </style>
</resources>