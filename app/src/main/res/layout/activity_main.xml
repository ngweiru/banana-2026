<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <RelativeLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        tools:context=".MainActivity">

        <TextView
            android:id="@+id/itemNameTxt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Item Name:"
            android:textColor="@color/black"
            android:padding="16dp"/>

        <TextView
            android:id="@+id/itemName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:padding="16dp"
            android:layout_below="@id/itemNameTxt"/>

        <TextView
            android:id="@+id/weightTxt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Weight:"
            android:textColor="@color/black"
            android:padding="16dp"
            android:layout_below="@id/itemName"/>

        <TextView
            android:id="@+id/weight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:padding="16dp"
            android:layout_below="@id/weightTxt"/>

        <TextView
            android:id="@+id/recylcComponentsTxt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Recyclable Components:"
            android:textColor="@color/black"
            android:padding="16dp"
            android:layout_below="@id/weight"/>

        <TextView
            android:id="@+id/recylcComponents"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:padding="16dp"
            android:layout_below="@id/recylcComponentsTxt"/>

        <TextView
            android:id="@+id/hazMatTxt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Hazardous Materials:"
            android:textColor="@color/black"
            android:padding="16dp"
            android:layout_below="@id/recylcComponents"/>

        <TextView
            android:id="@+id/hazMat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:padding="16dp"
            android:layout_below="@id/hazMatTxt"/>

        <TextView
            android:id="@+id/reuseRecTxt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Reuse Recommendations:"
            android:textColor="@color/black"
            android:padding="16dp"
            android:layout_below="@id/hazMat"/>

        <TextView
            android:id="@+id/reuseRec"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:padding="16dp"
            android:layout_below="@id/reuseRecTxt"/>

        <TextView
            android:id="@+id/impactTxt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Impact:"
            android:textColor="@color/black"
            android:padding="16dp"
            android:layout_below="@id/reuseRec"/>

        <TextView
            android:id="@+id/impact"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:padding="16dp"
            android:layout_below="@id/impactTxt"/>

        <Button
            android:id="@+id/uploadButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload Image"
            android:layout_below="@id/impact"
            android:layout_centerHorizontal="true"/>

        <ImageView
            android:id="@+id/IVPreviewImage"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/uploadButton"/>

    </RelativeLayout>
</ScrollView>
